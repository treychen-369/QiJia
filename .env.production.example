# ============================================
# 生产环境配置示例 (.env.production)
# ============================================
# 使用方法：
# 1. 复制此文件为 .env.production
# 2. 填写实际的生产环境变量值
# 3. 确保 .env.production 在 .gitignore 中（已包含）

# ============================================
# 数据库配置
# ============================================
DATABASE_URL="postgresql://finance_user:YOUR_DB_PASSWORD@postgres:5432/finance_system"

# ============================================
# NextAuth 配置
# ============================================
# 你的生产域名（必须与nginx配置一致）
NEXTAUTH_URL="http://YOUR_DOMAIN_OR_IP"

# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET="YOUR_SECRET_KEY_HERE"

# ============================================
# API 密钥
# ============================================
# DeepSeek API Key（如果使用AI功能）
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# ============================================
# Redis 配置
# ============================================
REDIS_URL="redis://redis:6379"

# ============================================
# 应用配置
# ============================================
NODE_ENV=production

# 日志级别 (ERROR, WARN, INFO, DEBUG)
LOG_LEVEL=WARN

# ============================================
# 邮件配置（可选，如果需要邮件通知）
# ============================================
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="your_email@example.com"
# SMTP_PASSWORD="your_email_password"
# SMTP_FROM="noreply@example.com"

# ============================================
# 其他配置
# ============================================
# 时区设置
TZ=Asia/Shanghai
