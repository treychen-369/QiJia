# ============================================
# 开发环境配置模板
# ============================================
# 复制为 .env.dev 并填入本地开发配置
# ============================================

# 数据库配置
POSTGRES_DB=finance_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

# NextAuth 配置
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-key-not-for-production

# AI 配置（可选）
DEEPSEEK_API_KEY=

# 应用配置
NODE_ENV=development
LOG_LEVEL=DEBUG
