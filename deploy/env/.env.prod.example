# ============================================
# 生产环境配置模板（腾讯云轻量服务器）
# ============================================
# 
# 📋 使用说明：
#   1. 复制此文件: cp .env.prod.example .env.prod
#   2. 编辑 .env.prod 填入真实配置
#   3. .env.prod 不会被提交到 Git（已在 .gitignore）
#
# ⚠️ 重要提示：
#   - 数据库密码不要包含特殊字符（如 ?!@#$ 等）
#   - 推荐使用纯字母数字的强密码
#
# 🔐 密钥说明详见: SECRETS_GUIDE.md
#
# ============================================

# ============================================
# 数据库配置（必填）
# ============================================
POSTGRES_DB=finance_system
POSTGRES_USER=finance_user

# ⚠️ 数据库密码 - 必须修改！
# 生成方式（生成纯字母数字密码，避免特殊字符导致 URL 解析错误）:
#   openssl rand -base64 24 | tr -dc 'a-zA-Z0-9'
# 或使用: head -c 24 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c 32
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ============================================
# NextAuth 配置（必填）
# ============================================

# 访问地址（根据部署模式修改）
# HTTP 模式（IP访问）: http://你的服务器IP
# HTTPS 模式（域名）: https://your-domain.com
NEXTAUTH_URL=http://your-server-ip

# ⚠️ 会话加密密钥 - 必须修改！
# 生成方式: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_USE_RANDOM_STRING

# ============================================
# Cookie 配置（重要！）
# ============================================
# HTTP 模式必须设为 false，否则登录后无法保持会话
# HTTPS 模式设为 true
COOKIE_SECURE=false

# ============================================
# AI 配置（可选）
# ============================================
# 如果不使用 AI 功能，留空即可
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ============================================
# 应用配置（通常不需要修改）
# ============================================
NODE_ENV=production
LOG_LEVEL=WARN
TZ=Asia/Shanghai
