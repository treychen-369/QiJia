# ============================================
# QiJia (齐家) - 环境变量配置模板
# ============================================
# ⚠️ 重要：请复制此文件为 .env.local 并填入您的真实配置
# ⚠️ 切勿将包含真实密钥的文件提交到 Git 仓库

# ============================================
# 数据库配置（必须）
# ============================================
DATABASE_URL="postgresql://username:password@localhost:5432/finance_system"

# ============================================
# NextAuth.js 配置（必须）
# ============================================
NEXTAUTH_URL="http://localhost:3000"
# 生产环境请生成强随机密钥：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# ============================================
# DeepSeek AI 配置（可选，用于 AI 建议功能）
# ============================================
# 注册地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ============================================
# 证券数据 API 配置（可选）
# ============================================
# 是否启用证券API（true/false）
SECURITIES_API_ENABLED="false"

# API提供商: tushare, yahoo, alphavantage, manual
SECURITIES_API_PROVIDER="manual"

# Tushare配置（推荐用于A股/港股）
# 注册地址: https://tushare.pro/register
SECURITIES_API_KEY="your-tushare-token"
SECURITIES_API_ENDPOINT="https://api.tushare.pro"

# 或 Alpha Vantage配置（免费用于美股）
# 注册地址: https://www.alphavantage.co/support/#api-key
# SECURITIES_API_KEY="your-alphavantage-key"
# SECURITIES_API_ENDPOINT="https://www.alphavantage.co"

# API速率限制（每分钟请求次数）
SECURITIES_API_RATE_LIMIT="60"

# ============================================
# 邮件服务配置（可选）
# ============================================
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email@example.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="your-email@example.com"

# ============================================
# Redis 配置（可选，用于缓存）
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# 应用配置
# ============================================
NODE_ENV="development"
PORT=3000

# ============================================
# 日志配置
# ============================================
# 日志级别: debug, info, warn, error, none
# - debug: 显示所有日志（仅开发环境推荐）
# - info: 显示 info, warn, error 日志
# - warn: 显示 warn, error 日志（生产环境推荐）
# - error: 仅显示 error 日志
# - none: 禁用所有日志
LOG_LEVEL="info"

# 是否启用日志输出 (true/false)
LOG_ENABLED="true"

# 是否显示敏感信息 (true/false)
# ⚠️ 警告: 生产环境中必须设置为 false
LOG_SENSITIVE="false"

# ============================================
# 文件上传配置
# ============================================
MAX_FILE_SIZE="10485760"  # 10MB
UPLOAD_DIR="./uploads"

# ============================================
# 安全配置
# ============================================
# 生产环境请设置为您的域名
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000  # 15分钟
